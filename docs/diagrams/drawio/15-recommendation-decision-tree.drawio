          <mxGeometry x="300" y="20" width="600" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Primary score-based recommendation with fallback heuristic for incomplete or low-confidence hardware evidence" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="300" y="50" width="600" height="24" as="geometry"/>
