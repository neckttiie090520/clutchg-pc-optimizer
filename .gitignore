# ============================================================
# ClutchG PC Optimizer — Root .gitignore
# ============================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.spec
*.manifest

# ---------- Virtual Environment ----------
venv/
.venv/
env/

# ---------- pytest / coverage ----------
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# ---------- OS ----------
Thumbs.db
Desktop.ini
.DS_Store

# ---------- Binary Documents (catch-all) ----------
*.pdf
*.docx
*.xlsx
*.pptx
*.zip
*.exe
*.dll

# ============================================================
# Privacy — Thesis / Academic / Personal Content
# ============================================================

# Thesis chapters (student name, advisor, university info)
thesis-chapters/

# Thesis documentation hub (academic scaffolding)
THESIS_DOCS/

# Notion import scripts (CONTAINS HARDCODED NOTION TOKEN)
scripts/

# ISO 29110 templates/forms (university forms, other students' info)
docs/iso29110/

# Notion-imported course materials (entire dir)
docs/notion-imports/

# University proposal extracts (student ID, name, advisor, signatures)
docs/proposal-vs-current-state.md
docs/_proposal_extract_*.txt



# ============================================================
# Reference / Research Material (not product code)
# ============================================================

# Research repos (~1 GB third-party clones)
research/

# Cloned third-party repo
awesome-ai-research-writing-main/

# Raw Notion export (binary Office docs)
notion/

# Reference notes (PDFs + duplicates)
Ideas and research/

# UX working files (keep UI design/ tracked)
UX/design-reference/
UX/live/
UX/3/
UX/lasted UI/
UX/UI design/redesign-v1/
UX/capture_*.py
UX/test*.png
UX/INDEX.md
UX/[0-9][0-9]-*.png

# Untracked GUID images in img/
img/{*.png

# ============================================================
# AI Tool Configs (auto-generated, machine-specific)
# ============================================================
.agents/
.claude/
.opencode/
.codex/
.kilocode/
.kilocodemodes
.factory/
.windsurf/
.bug-hunter/
.letta/
skills/
psi/
opencode.json
CLAUDE.md

# ============================================================
# ClutchG App Runtime
# ============================================================

# Runtime data
clutchg/data/
clutchg/config/*.json
!clutchg/config/default_config.json

# Build artifacts
clutchg/dist/
clutchg/build/

# ============================================================
# Repo Map (auto-generated, local-only)
# ============================================================
mapping.md

# ============================================================
# Misc
# ============================================================
*.log
nul
NUL
*.code-workspace
.benchmarks/
.superpowers/
.ruff_cache/
docsdiagrams/

# SE academic course analysis (private supporting material)
docs/se-academic/
